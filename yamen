<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pivot — We Don't Post. We Position.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --crimson: #8B0000;
    --crimson-light: #A50000;
    --black: #111111;
    --off-white: #F5F2EE;
    --warm-gray: #E8E3DC;
    --mid-gray: #9A9490;
    --text-dark: #1A1714;
    --serif: 'Playfair Display', Georgia, serif;
    --sans: 'Inter', sans-serif;
    --arabic: 'Tajawal', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--off-white);
    color: var(--text-dark);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  [lang="ar"] body, body.ar {
    font-family: var(--arabic);
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 900;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 28px;
    background: rgba(245, 242, 238, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(139,0,0,0.08);
    transition: padding 0.3s ease;
  }

  nav.scrolled {
    padding: 12px 28px;
    background: rgba(245, 242, 238, 0.97);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo svg {
    width: 36px;
    height: 36px;
  }

  .nav-logo-text {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--black);
    letter-spacing: 0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    color: var(--mid-gray);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--crimson); }

  .lang-toggle {
    background: none;
    border: 1.5px solid var(--crimson);
    color: var(--crimson);
    font-size: 12px;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 20px;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: all 0.2s;
    font-family: inherit;
  }

  .lang-toggle:hover {
    background: var(--crimson);
    color: white;
  }

  /* ─── SECTION LABELS ─── */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--crimson);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .section-label::after {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--crimson);
    opacity: 0.5;
  }

  /* ─── HOME SECTION ─── */
  #home {
    min-height: 100vh;
    padding: 110px 28px 60px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 50px;
    max-width: 540px;
    margin: 0 auto;
  }

  .home-content { position: relative; }

  .hero-tagline {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mid-gray);
    margin-bottom: 24px;
  }

  .hero-headline {
    font-family: var(--serif);
    font-size: clamp(38px, 10vw, 56px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--black);
    margin-bottom: 24px;
  }

  .hero-headline span { color: var(--crimson); }

  .hero-body {
    font-size: 15px;
    color: #5A5653;
    line-height: 1.75;
    margin-bottom: 36px;
    max-width: 400px;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 36px;
  }

  .meta-chip {
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 20px;
    background: var(--warm-gray);
    color: var(--text-dark);
    letter-spacing: 0.02em;
  }

  .meta-chip.accent {
    background: var(--crimson);
    color: white;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--crimson);
    color: white;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 14px 28px;
    border-radius: 4px;
    transition: all 0.25s;
  }

  .hero-cta:hover {
    background: var(--black);
    transform: translateY(-2px);
  }

  .home-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-photo-wrap {
    position: relative;
    width: 260px;
    height: 320px;
  }

  .hero-blob {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 240px;
    height: 280px;
    background: var(--crimson);
    opacity: 0.08;
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
  }

  .hero-photo {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    filter: grayscale(10%);
  }

  .hero-photo-card {
    position: absolute;
    bottom: -16px;
    left: -20px;
    z-index: 3;
    background: white;
    border-radius: 10px;
    padding: 12px 16px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
  }

  .hero-photo-card .stat-num {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--crimson);
    line-height: 1;
  }

  .hero-photo-card .stat-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--mid-gray);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 2px;
  }

  /* ─── SERVICES STRIP ─── */
  .services-strip {
    background: var(--black);
    padding: 40px 28px;
    overflow: hidden;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 540px;
    margin: 0 auto;
  }

  .service-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 18px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    transition: border-color 0.25s;
  }

  .service-item:hover { border-color: var(--crimson); }

  .service-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: var(--crimson);
  }

  .service-name {
    font-size: 13px;
    font-weight: 500;
    color: white;
    line-height: 1.4;
  }

  .services-header {
    text-align: center;
    margin-bottom: 28px;
  }

  .services-header .section-label {
    justify-content: center;
    color: rgba(255,255,255,0.4);
  }

  .services-header .section-label::after { background: rgba(255,255,255,0.2); }

  .services-header h2 {
    font-family: var(--serif);
    font-size: 28px;
    color: white;
    font-weight: 700;
  }

  /* ─── RESULTS STRIP ─── */
  .results-strip {
    background: var(--crimson);
    padding: 36px 28px;
  }

  .results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 540px;
    margin: 0 auto;
  }

  .result-stat {
    text-align: center;
  }

  .result-num {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 900;
    color: white;
    line-height: 1;
  }

  .result-desc {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.04em;
    margin-top: 4px;
  }

  /* ─── PORTFOLIO ─── */
  #portfolio {
    padding: 80px 28px 60px;
    max-width: 540px;
    margin: 0 auto;
  }

  .portfolio-intro {
    margin-bottom: 44px;
  }

  .portfolio-intro h2 {
    font-family: var(--serif);
    font-size: clamp(30px, 8vw, 42px);
    font-weight: 900;
    color: var(--black);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .portfolio-intro p {
    font-size: 14px;
    color: var(--mid-gray);
    line-height: 1.7;
  }

  /* ─── CASE CARDS ─── */
  .case-card {
    margin-bottom: 48px;
    border-radius: 14px;
    overflow: hidden;
    background: white;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .case-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.1);
  }

  .case-visual {
    position: relative;
    width: 100%;
    aspect-ratio: 9/16;
    background: #1a1a1a;
    overflow: hidden;
  }

  .case-visual video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .case-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .unmute-btn {
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 10;
  }

  .unmute-btn:hover { background: var(--crimson); }

  .case-body {
    padding: 22px 20px 24px;
  }

  .case-client {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--crimson);
    margin-bottom: 6px;
  }

  .case-title {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .case-desc {
    font-size: 13px;
    color: #6A6460;
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .case-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .case-tag {
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 12px;
    background: var(--warm-gray);
    color: var(--text-dark);
  }

  .case-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding-top: 16px;
    border-top: 1px solid var(--warm-gray);
  }

  .case-result-item .num {
    font-family: var(--serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--crimson);
    line-height: 1;
  }

  .case-result-item .label {
    font-size: 11px;
    color: var(--mid-gray);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 2px;
  }

  /* ─── WORK GRID (images) ─── */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 48px;
  }

  .work-grid-item {
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 3/4;
    background: var(--warm-gray);
  }

  .work-grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .work-grid-item:hover img { transform: scale(1.04); }

  /* ─── CONTACT ─── */
  #contact {
    padding: 80px 28px 100px;
    max-width: 540px;
    margin: 0 auto;
  }

  .contact-card {
    background: var(--black);
    border-radius: 20px;
    padding: 40px 28px;
    color: white;
  }

  .contact-header {
    margin-bottom: 36px;
  }

  .contact-header .section-label {
    color: rgba(255,255,255,0.35);
  }

  .contact-header .section-label::after { background: rgba(255,255,255,0.15); }

  .contact-header h2 {
    font-family: var(--serif);
    font-size: 30px;
    font-weight: 900;
    color: white;
    line-height: 1.2;
    margin-bottom: 10px;
  }

  .contact-header p {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 18px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    text-decoration: none;
    color: white;
    transition: all 0.25s;
    background: rgba(255,255,255,0.03);
  }

  .contact-link:hover {
    border-color: var(--crimson);
    background: rgba(139,0,0,0.15);
    transform: translateX(4px);
  }

  html[dir="rtl"] .contact-link:hover {
    transform: translateX(-4px);
  }

  .contact-link-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-link-icon svg {
    width: 22px;
    height: 22px;
  }

  .contact-link-info { flex: 1; }

  .contact-link-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2px;
  }

  .contact-link-value {
    font-size: 15px;
    font-weight: 500;
    color: white;
  }

  .contact-link-arrow {
    color: rgba(255,255,255,0.2);
    transition: color 0.2s;
  }

  .contact-link:hover .contact-link-arrow { color: var(--crimson); }

  /* ─── FOOTER ─── */
  footer {
    background: var(--black);
    padding: 24px 28px;
    text-align: center;
  }

  .footer-tagline {
    font-family: var(--serif);
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    font-style: italic;
  }

  .footer-tagline span { color: var(--crimson); }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }

  /* ─── RTL SUPPORT ─── */
  html[dir="rtl"] .section-label::after {
    order: -1;
  }

  html[dir="rtl"] .hero-blob {
    right: auto;
    left: -20px;
  }

  html[dir="rtl"] .hero-photo-card {
    left: auto;
    right: -20px;
  }

  html[dir="rtl"] nav {
    flex-direction: row-reverse;
  }

  html[dir="rtl"] body {
    font-family: var(--arabic);
  }

  html[dir="rtl"] .hero-headline,
  html[dir="rtl"] .portfolio-intro h2,
  html[dir="rtl"] .contact-header h2,
  html[dir="rtl"] .services-header h2 {
    font-family: var(--arabic);
    font-weight: 700;
  }

  /* ─── REEL LINK ─── */
  .reel-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 16px 20px 20px;
    padding: 10px 18px;
    background: var(--off-white);
    border: 1.5px solid var(--warm-gray);
    border-radius: 30px;
    text-decoration: none;
    color: var(--text-dark);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: all 0.22s;
  }
  .reel-link:hover {
    border-color: var(--crimson);
    color: var(--crimson);
    background: white;
  }
  .reel-link svg { flex-shrink: 0; }

  /* ─── DIVIDER ─── */
  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--warm-gray), transparent);
    margin: 0;
  }

  /* Mobile menu hidden on small screens */
  @media (max-width: 480px) {
    .nav-links { display: none; }
    .nav-mobile-links {
      display: flex;
      gap: 18px;
    }
    .nav-mobile-links a {
      font-size: 12px;
      color: var(--mid-gray);
      text-decoration: none;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
  }

  @media (min-width: 481px) {
    .nav-mobile-links { display: none; }
  }
</style>
</head>
<body>

<!-- ═══ NAV ═══ -->
<nav id="main-nav">
  <a href="#home" class="nav-logo">
    <!-- Pivot Logo SVG -->
    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="52" y="28" width="24" height="44" rx="4" fill="#8B0000"/>
      <rect x="52" y="28" width="24" height="24" rx="4" fill="#8B0000"/>
      <rect x="40" y="28" width="12" height="44" rx="4" fill="#8B0000"/>
      <path d="M40 52 L20 52 L28 44 M20 52 L28 60" stroke="#8B0000" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="52" y="32" width="16" height="16" rx="2" fill="#F5F2EE"/>
    </svg>
    <span class="nav-logo-text" data-en="Pivot" data-ar="بيفوت">Pivot</span>
  </a>

  <ul class="nav-links">
    <li><a href="#home" data-en="Home" data-ar="الرئيسية">Home</a></li>
    <li><a href="#portfolio" data-en="Work" data-ar="أعمالنا">Work</a></li>
    <li><a href="#contact" data-en="Contact" data-ar="تواصل">Contact</a></li>
  </ul>

  <div style="display:flex;align-items:center;gap:14px;">
    <div class="nav-mobile-links">
      <a href="#portfolio" data-en="Work" data-ar="أعمالنا">Work</a>
      <a href="#contact" data-en="Contact" data-ar="تواصل">Contact</a>
    </div>
    <button class="lang-toggle" id="langBtn" onclick="toggleLang()">عربي</button>
  </div>
</nav>

<!-- ═══ HOME ═══ -->
<section id="home">
  <div class="home-content reveal">
    <p class="hero-tagline" data-en="Marketing Agency — Ramallah, Palestine" data-ar="وكالة تسويق — رام الله، فلسطين">Marketing Agency — Ramallah, Palestine</p>
    <h1 class="hero-headline">
      <span data-en="We Don't" data-ar="لا نُنشر">We Don't</span><br>
      <span data-en="Post." data-ar="نُموضع">Post.</span><br>
      <span data-en="We Position." data-ar="نُموضع.">We Position.</span>
    </h1>
    <p class="hero-body" data-en="Pivot is a results-driven marketing agency. We build brands, tell stories, and deliver campaigns that move the numbers — not just the feed." data-ar="بيفوت وكالة تسويق تعمل على النتائج. نبني علامات تجارية، نروي قصصاً، وننفذ حملات تحرّك الأرقام — لا مجرد المنشورات.">
      Pivot is a results-driven marketing agency. We build brands, tell stories, and deliver campaigns that move the numbers — not just the feed.
    </p>
    <div class="meta-row">
      <span class="meta-chip accent" data-en="Available Now" data-ar="متاح الآن">Available Now</span>
      <span class="meta-chip" data-en="Video Production" data-ar="إنتاج الفيديو">Video Production</span>
      <span class="meta-chip" data-en="Content Creation" data-ar="إنشاء المحتوى">Content Creation</span>
    </div>
    <a href="#contact" class="hero-cta">
      <span data-en="Work With Us" data-ar="تعاون معنا">Work With Us</span>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>

  <div class="home-visual reveal reveal-delay-1">
    <div class="hero-photo-wrap">
      <div class="hero-blob"></div>
      <img src="IMG_1426.PNG" alt="Pivot team" class="hero-photo" onerror="this.src='IMG_1425.PNG'">
      <div class="hero-photo-card">
        <div class="stat-num">707%</div>
        <div class="stat-label" data-en="Views Growth" data-ar="نمو المشاهدات">Views Growth</div>
