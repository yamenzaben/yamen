<script>
  // ─── LANGUAGE TOGGLE ───
  let isArabic = localStorage.getItem('pivot-lang') === 'ar';

  function applyLang() {
    const html = document.documentElement;
    const btn = document.getElementById('langBtn');
    
    if (isArabic) {
      html.setAttribute('lang', 'ar');
      html.setAttribute('dir', 'rtl');
      btn.textContent = 'English';
      document.querySelectorAll('[data-ar]').forEach(el => {
        if (!el.dataset.originalContent) el.dataset.originalContent = el.textContent;
        el.textContent = el.dataset.ar;
      });
    } else {
      html.setAttribute('lang', 'en');
      html.setAttribute('dir', 'ltr');
      btn.textContent = 'عربي';
      document.querySelectorAll('[data-en]').forEach(el => {
        el.textContent = el.dataset.en;
      });
    }
  }

  function toggleLang() {
    isArabic = !isArabic;
    localStorage.setItem('pivot-lang', isArabic ? 'ar' : 'en');
    applyLang();
  }

  applyLang();

  // ─── NAV SCROLL ───
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  });

  // ─── SCROLL REVEAL ───
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ─── UNMUTE BUTTONS ───
  document.querySelectorAll('.case-visual').forEach(wrap => {
    const video = wrap.querySelector('video');
    const btn = wrap.querySelector('.unmute-btn');
    if (!video || !btn) return;

    btn.style.display = 'flex';
    let muted = true;

    btn.addEventListener('click', () => {
      muted = !muted;
      video.muted = muted;
      btn.innerHTML = muted
        ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" fill="white"/><path d="M23 9l-6 6M17 9l6 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>`
        : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" fill="white"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>`;
    });
  });
</script>
